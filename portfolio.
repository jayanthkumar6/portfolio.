</header>

<main>
  <!-- HERO -->
  <section class="hero" style="border-top:none;padding-top:140px;">
    <div class="wrap">
      <div class="eyebrow"><span class="dot"></span>OPEN TO OPPORTUNITIES · BENGALURU, IN</div>
      <h1>Edara Jayanth Kumar<br><span class="accent-word">VLSI Physical Design</span> Engineer</h1>
      <p class="hero-sub">ASIC Physical Design · RTL-to-GDSII flow · Timing closure &amp; PPA optimization</p>
      <div class="hero-loc">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        Bengaluru, India
      </div>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">View Projects</a>
        <a href="#contact" class="btn btn-ghost">Get in Touch</a>
      </div>
      <div class="datasheet reveal" id="datasheet">
        <div class="ds-cell"><div class="ds-label">Node</div><div class="ds-value">7nm / 90nm</div></div>
        <div class="ds-cell"><div class="ds-label">Flow</div><div class="ds-value">RTL → GDSII</div></div>
        <div class="ds-cell"><div class="ds-label">Tools</div><div class="ds-value">Genus · Innovus</div></div>
        <div class="ds-cell"><div class="ds-label">Focus</div><div class="ds-value">Timing Closure</div></div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="sec-tag">01 · About</span>
        <h2>Building silicon from RTL to signoff.</h2>
      </div>
      <div class="about-grid">
        <div class="about-text reveal">
          <p><strong>Edara Jayanth Kumar</strong> is a VLSI Physical Design Engineer with hands-on experience across the complete <strong>RTL-to-GDSII ASIC Physical Design flow</strong> using <strong>Cadence Genus</strong> and <strong>Cadence Innovus</strong>.</p>
          <p>He has worked on <strong>90nm full-chip</strong> and <strong>7nm block-level</strong> designs, gaining practical exposure to RTL synthesis, floorplanning, power planning, placement, clock tree synthesis, routing, static timing analysis, timing closure, and MMMC optimization.</p>
          <p>He enjoys solving timing challenges, improving Power-Performance-Area, and is currently seeking opportunities to contribute as a VLSI Physical Design Engineer in the semiconductor industry.</p>
        </div>
        <div class="about-photo reveal" id="aboutPhoto">
          <div class="photo-placeholder">EJK</div>
        </div>
      </div>
    </div>
  </section>

  <svg class="clock-divider reveal" viewBox="0 0 1120 34" preserveAspectRatio="none"><path d="M0,17 L60,17 L60,5 L120,5 L120,29 L180,29 L180,17 L260,17 L260,5 L320,5 L320,29 L380,29 L380,17 L460,17 L460,5 L520,5 L520,29 L580,29 L580,17 L660,17 L660,5 L720,5 L720,29 L780,29 L780,17 L860,17 L860,5 L920,5 L920,29 L980,29 L980,17 L1060,17 L1060,5 L1120,5"></path></svg>

  <!-- SKILLS -->
  <section id="skills">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="sec-tag">02 · Skills</span>
        <h2>Technical toolkit</h2>
      </div>
      <div class="skills-grid reveal">
        <div class="skill-card">
          <h3>PD Tools</h3>
          <div class="skill-tags">
            <span class="tag">Cadence Innovus</span><span class="tag">Cadence Genus</span>
          </div>
        </div>
        <div class="skill-card">
          <h3>Physical Design Flow</h3>
          <div class="skill-tags">
            <span class="tag">RTL Synthesis</span><span class="tag">Floorplanning</span><span class="tag">Power Planning</span><span class="tag">Placement</span><span class="tag">CTS</span><span class="tag">Routing</span><span class="tag">STA</span><span class="tag">Timing Closure</span><span class="tag">ECO</span><span class="tag">Physical Verification</span>
          </div>
        </div>
        <div class="skill-card">
          <h3>Timing Analysis</h3>
          <div class="skill-tags">
            <span class="tag">Setup Analysis</span><span class="tag">Hold Analysis</span><span class="tag">Clock Latency</span><span class="tag">Clock Skew</span><span class="tag">Timing Paths</span><span class="tag">Slack Analysis</span><span class="tag">MMMC</span><span class="tag">RC Corners</span>
          </div>
        </div>
        <div class="skill-card">
          <h3>Power Analysis</h3>
          <div class="skill-tags">
            <span class="tag">IR Drop</span><span class="tag">Power Analysis</span><span class="tag">Power Planning</span><span class="tag">Low Power Flow</span>
          </div>
        </div>
        <div class="skill-card">
          <h3>Programming &amp; Scripting</h3>
          <div class="skill-tags">
            <span class="tag">TCL</span><span class="tag">Shell Scripting</span>
          </div>
        </div>
        <div class="skill-card">
          <h3>Operating Systems</h3>
          <div class="skill-tags">
            <span class="tag">Linux</span><span class="tag">Windows</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="experience">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="sec-tag">03 · Experience</span>
        <h2>Where the flow was built</h2>
      </div>
      <div class="timeline reveal">
        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-head">
            <div class="tl-role">Physical Design Engineer Intern</div>
